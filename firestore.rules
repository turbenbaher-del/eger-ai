rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function validString(field, maxLen) {
      return field is string && field.size() <= maxLen;
    }

    // Catches: только владелец читает и пишет свои записи
    match /catches/{userId}/records/{recordId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // Публичные записи (лента сообщества)
    match /reports/{recordId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && (!('text' in request.resource.data) || validString(request.resource.data.text, 2000))
        && (!('photoUrls' in request.resource.data) || (request.resource.data.photoUrls is list && request.resource.data.photoUrls.size() <= 4));
      allow update: if isAuth() && (
        resource.data.userId == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
      );
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Значки: читать может любой авторизованный, писать — только Cloud Functions (сервисный аккаунт)
    match /users/{userId}/badges/{badgeId} {
      allow read: if isAuth();
      allow write: if false; // только Cloud Functions
    }

    // Профиль пользователя
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() && isOwner(userId);
      allow update: if isAuth() && isOwner(userId)
        && (!('displayName' in request.resource.data) || validString(request.resource.data.displayName, 50))
        && (!('photoURL' in request.resource.data) || validString(request.resource.data.photoURL, 500))
        && (!('bio' in request.resource.data) || validString(request.resource.data.bio, 300));
      allow delete: if false;
    }

    // Рейтинг: только чтение для авторизованных, запись — Cloud Functions
    match /leaderboard/{period}/rows/{userId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Турниры: только чтение; участники — пользователь пишет свою запись
    match /tournaments/{tournamentId} {
      allow read: if isAuth();
      allow write: if false;
    }
    match /tournaments/{tournamentId}/participants/{userId} {
      allow read: if isAuth();
      allow write: if isAuth() && isOwner(userId);
    }

    // Чат сообщества
    match /messages/{messageId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.uid == request.auth.uid ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions'])
          && request.resource.data.reactions is map
          && request.resource.data.reactions.size() <= 20
        )
      );
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Уровень воды: только чтение
    match /water_levels/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // FCM токены: пользователь пишет только свой токен
    match /fcm_tokens/{tokenId} {
      allow read: if false;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth()
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Push лог: только Cloud Functions
    match /push_log/{userId} {
      allow read, write: if false;
    }

    // Новости
    match /news/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Личные сообщения (DM)
    match /dms/{dmId} {
      allow read: if isAuth() && request.auth.uid in resource.data.participants;
      allow create: if isAuth() && request.auth.uid in request.resource.data.participants
        && request.resource.data.participants.size() == 2;
      allow update: if isAuth() && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if false;
    }
    match /dms/{dmId}/messages/{msgId} {
      allow read: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid && request.auth.uid in get(/databases/$(database)/documents/dms/$(dmId)).data.participants;
      allow delete: if isAuth() && resource.data.uid == request.auth.uid;
    }

    // Счётчик использования ИИ — только Cloud Functions
    match /ai_usage/{userId} {
      allow read, write: if false;
    }

    // Отчёты об ошибках — клиент пишет, читают только Cloud Functions
    match /crash_reports/{docId} {
      allow read: if false;
      allow create: if true; // пишем даже без авторизации (crash может быть до auth)
    }

    // База знаний бота (накопленные ответы Claude) — читают клиенты, пишут только Cloud Functions
    match /bot_kb/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }

    // Предложенные точки (модерируются)
    match /suggested_spots/{docId} {
      allow read: if false; // только Cloud Functions и модераторы
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }

    // Барахолка (объявления)
    match /classifieds/{docId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && validString(request.resource.data.title, 200)
        && validString(request.resource.data.contact, 100);
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // Настройки уведомлений
    match /notification_prefs/{userId} {
      allow read, write: if isAuth() && isOwner(userId);
    }

    // Кэш давления для push-уведомлений (только Cloud Functions)
    match /_meta/{docId} {
      allow read: if isAuth();
      allow write: if false;
    }
  }
}
